{
  "name": "blackbox/api",
  "description": "Blackbox API (Slim PHP)",
  "type": "project",
  "require": {
    "php": "^8.3",
    "monolog/monolog": "^3.0",
    "php-di/php-di": "^7.0",
    "slim/psr7": "^1.7",
    "slim/slim": "^4.14",
    "stripe/stripe-php": "^16.0",
    "symfony/dotenv": "^7.2",
    "symfony/mailer": "^7.2",
    "symfony/mime": "^7.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "robmorgan/phinx": "^0.16.10",
    "symfony/config": "^7.3",
    "symfony/console": "^7.3",
    "symfony/filesystem": "^7.3",
    "symfony/string": "^7.3"
  },
  "scripts": {
    "migrate": "./vendor/bin/phinx migrate -c phinx.php",
    "migrate:status": "./vendor/bin/phinx status -c phinx.php",
    "seed:run": "./vendor/bin/phinx seed:run -c phinx.php"
  },
  "autoload": {
    "psr-4": {
      "Blackbox\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Blackbox\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
