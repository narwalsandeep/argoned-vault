# Copy to `api/.env` and adjust values. This file is the single env template: there is no repo-root `.env`.
#
# Hosted (argoned.com) and self-hosted (OSS) use the **same variables** — only values differ (your Stripe, mail,
# ADMIN_EMAIL, DB passwords). See docs/self-host.md. OSS publish credentials (OSS_PUBLISH_GITHUB_TOKEN) live in
# GitHub Actions secrets on the private repo only — not here.
#
# Docker Compose published ports: from the `vault/` directory always run:
#   docker compose --env-file ./api/.env …
# next to `docker-compose.yml` also works for interpolation if you do not use --env-file.
#
# Loaded automatically:
# - PHP: `bootstrap/app.php` and `phinx.php` (Symfony Dotenv; does not override variables already set by the OS).
# - Docker Compose: `env_file` on `api`, `db`, `ui`, and `website` services (see `vault/docker-compose.yml`). Compose overrides **`DB_HOST`** and **`DB_PORT`** for the **`api`** container (`db` + `5432`) so PHP connects inside the Docker network. The `db` service maps `DB_*` to the
#   image's `POSTGRES_*` internally; keep credentials only here. The `ui` and `website` services receive the same keys where relevant for dev tooling; the Angular apps in the browser use their own configs unless you wire substitution.

# App environment (must be `production` in real deploys). Anything else enables dev-only routes such as
# GET /api/v1/dev/email-templates (live HTML previews of auth emails; see vault/docs/system-reference.md).
APP_ENV=local

# Machine-readable Terms + Privacy bundle id at signup (must match vault UI `LEGAL_SIGNUP_DOCS_VERSION`; bump when policies change materially).
LEGAL_SIGNUP_DOCS_VERSION=2026-04-16

# Service ports
UI_PORT=3002
API_PORT=3003

# Origins and URLs
UI_ORIGIN=http://localhost:3002
# Optional: comma-separated list (overrides single UI_ORIGIN when set)
# UI_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
API_BASE_URL=http://localhost:3003

# Public URL of this API as seen by the browser (scheme + host + port, no trailing slash). Used to build OAuth
# redirect_uri: {API_PUBLIC_BASE_URL}/api/v1/auth/oauth/callback — must match exactly what you register at Google,
# LinkedIn, and Facebook. In Docker, use the host URL clients use (e.g. http://localhost:3003), not an internal hostname.
API_PUBLIC_BASE_URL=http://localhost:3003

# Production static UI (`docker-compose.prod.yml` nginx): CSP `connect-src` extra origins (API base URL(s), space-separated).
# Must align with `apiBaseUrl` in `ui/src/environments/environment.prod.ts`. Default if unset: https://api.argoned.com
# NGINX_UI_CONNECT_SRC=https://api.argoned.com

# --- OAuth sign-in (Google, LinkedIn, Facebook) ---
# Leave client id + secret pairs empty to disable that provider. Secrets must never be committed; set them only in api/.env.
# Authorize URL: GET {API_PUBLIC_BASE_URL}/api/v1/auth/oauth/{google|linkedin|facebook}/start
# Callback URL (register this at each IdP): {API_PUBLIC_BASE_URL}/api/v1/auth/oauth/callback
# Optional: how long the anti-CSRF state row remains valid (seconds). Default 600 if unset or invalid.
OAUTH_STATE_TTL_SECONDS=600
#
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
#
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=
#
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=

# Database (API, Phinx, and Docker Postgres).
#
# Postgres is published on host **5454** (→ container **5432**). Keep **`DB_PORT=5454`** so tools on the host use `127.0.0.1:5454`.
# Compose overrides **`DB_HOST=db`** and **`DB_PORT=5432`** for the **`api`** container only (see `vault/docker-compose.yml`).
DB_HOST=127.0.0.1
DB_PORT=5454
DB_NAME=blackbox
DB_USER=blackbox
DB_PASSWORD=change-me

# pgAdmin in local `vault/docker-compose.yml` (not production). Sign in at http://localhost:${PGADMIN_PORT}/
# Add server: host `db`, port 5432 (use DB_NAME, DB_USER, DB_PASSWORD; internal DB port, not DB_PORT).
# PGADMIN_PORT=5050
# PGADMIN_EMAIL=admin@blackbox.local
# PGADMIN_PASSWORD=change-me

# Session cookie settings (API)
SESSION_COOKIE_NAME=bb_session
SESSION_TTL_SECONDS=86400
SESSION_SECURE_COOKIE=false

# Sign-in email OTP (6-digit code after password). Hashed server-side with this pepper; never log or commit real values to git.
# In APP_ENV=production this must be non-empty or login will return login_otp_misconfigured (503). In local/testing, if unset,
# the API uses a built-in dev-only default; still set a real secret for staging that receives real mail.
LOGIN_OTP_PEPPER=
# How long the sign-in email OTP remains valid (seconds). Default 120 (2 minutes) if omitted.
LOGIN_OTP_TTL_SECONDS=120

# Security hardening — max HTTP body Slim accepts (`PayloadSizeMiddleware`). Vault file items allow up to 20 MiB ciphertext plus JSON overhead; keep >= nginx `client_max_body_size` on api.argoned.com (see repo `aws-nginx.md`).
MAX_REQUEST_BYTES=26214400
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_RECOVERY_MAX=3
ACCOUNT_RECOVERY_ENABLED=false
ACCOUNT_RECOVERY_TOKEN=replace-with-long-random-value

# Stripe (optional). Price IDs (price_…), not prod_…. Pro = recurring; Lifetime = one-time.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_LINK_PRO=
STRIPE_PAYMENT_LINK_LIFETIME=
#
# Webhook URL in Stripe Dashboard must POST to this API route on the host that serves the PHP app (same path in all envs):
#   /api/v1/billing/webhook
# Example: if the API is at https://api.argoned.com use:
#   https://api.argoned.com/api/v1/billing/webhook
# If https://argoned.com only serves the SPA and proxies /api to the API, https://argoned.com/api/v1/billing/webhook is fine too.
# Configure the signing secret from Stripe as STRIPE_WEBHOOK_SECRET (per endpoint).

# Local only: when true AND APP_ENV=local, POST /api/v1/billing/dev-simulate-pro grants a synthetic Pro row (Host must be
# loopback). Disabled in production even if set. Never enable on a public host.
BILLING_DEV_SIMULATE_PRO=false

# When true, Free-plan users cannot use vault bulk import or (when shipped) encrypted file items. Pro/Lifetime keep access.
# Use false locally if Stripe is unset (everyone resolves as Free) and you need to test import.
VAULT_REQUIRE_NON_FREE_PLAN_FOR_IMPORT_AND_FILES=false

# UI (Angular): show the Lifetime tier card on /pricing. The SPA does not read this at runtime; mirror the same intent in
# `vault/ui/src/environments/environment.prod.ts` as `showLifetimeOnPricing: true|false` and rebuild the UI bundle.
# Documented here so `api/.env` stays the single operator-facing checklist with Stripe settings above.
UI_SHOW_LIFETIME_PRICING=false

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@example.com
MAIL_NAME=Argoned
MAIL_LOG_CHANNEL=
# Optional. When set to an account email (e.g. team@switchcodes.com), that user alone may call /api/v1/admin/* and sees Customers in the app shell.
ADMIN_EMAIL=
